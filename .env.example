# Copy to .env and fill in from your Supabase project (Settings → API,
# or Settings → General → "Reference ID" if the URL isn't shown directly:
# it's https://<reference-id>.supabase.co).
# EXPO_PUBLIC_* vars are inlined into the app bundle at build time.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only (never shipped). Used by scripts/ to seed content. Do NOT prefix with EXPO_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Visit Seoul API Center (Seoul Tourism Organization) — PRIMARY content source
# (English-native + linked Korean names, better tourist-facing quality than
# TourAPI). Sign up at https://api.visitseoul.net → 마이페이지 → API 키 관리.
# Used only by scripts/import-visitseoul.ts.
VISITSEOUL_API_KEY=

# TourAPI 4.0 (Korea Tourism Organization) — supplementary content source,
# used only by scripts/import-tourapi.ts. Korean-only (see that file's header
# for why English enrichment from TourAPI was abandoned).
# Apply at https://www.data.go.kr (search "한국관광공사" → apply for the API named below).
# Required: 한국관광공사_국문 관광정보 서비스_GW
TOURAPI_SERVICE_KEY=
# Optional (for English names/descriptions): 한국관광공사_영문 관광정보서비스_GW
# Leave blank to reuse TOURAPI_SERVICE_KEY once that's also approved.
TOURAPI_ENG_SERVICE_KEY=

# Naver Maps JavaScript SDK v3 Client ID (the "ncpKeyId"), used by
# components/WebMap.tsx (loaded inside a WebView — see docs/OPERATIONS.md).
# NCP Console → Services → Application Services → Maps → Application →
# register a "Web Dynamic Map" app (NOT Mobile — that tier has no free quota)
# with a Service URL, then copy its Client ID here. Public/client-exposed by
# design (Naver secures it via domain whitelisting, not secrecy) — leave
# blank to keep the stylized SVG fallback map.
EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=
